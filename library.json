{
    "name": "r2common",
    "description": "Common C++ utilities for Arduino microcontrollers — HTTP networking and Result types",
    "repository": {
        "type": "git",
        "url": "https://github.com/TordWessman/r2common"
    },
    "version": "0.0.1",
    "authors": [
        {
            "name": "TordWessman",
            "email": "tord@axelit.se",
            "url": "https://axelit.se/"
        }
    ],
    "includeDir": ".",
    "srcDir": ".",
    "frameworks": "arduino",
    "platforms": [
        "espressif8266",
        "espressif32",
        "atmelsam"
    ],
    "build": {
        "flags": [
            "-I .",
            "-I Network"
        ],
        "srcFilter": ["+<*>"],
        "libCompatMode": "strict"
    },
    "libLDFMode": "deep+"
}
